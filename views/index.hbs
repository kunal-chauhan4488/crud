{{>header}}
<title>Crud - Home</title>
{{>navbar}}
<div class="container-fluid my-3">
    <h5 class="bg-dark text-light p-2 text-center">Employee Data</h5>
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Designation</th>
                <th>Salary</th>
                <th>City</th>
                <th>state</th>
                <th></th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            {{#each data}}
            <tr>
                <td>{{_id}}</td>
                <td>{{name}}</td>
                <td>{{email}}</td>
                <td>{{phone}}</td>
                <td>{{designation}}</td>
                <td>{{salary}}</td>
                <td>{{city}}</td>
                <td>{{state}}</td>
                <td><a class="btn btn-dark" href="/edit/{{_id}}"><i class="fa fa-edit"></i></a></td>
                <td><a class="btn btn-danger" href="/delete/{{_id}}"><i class="fa fa-trash"></i></a></td>
            </tr>
            {{/each}}
        </tbody>
    </table>
</div>
{{>footer}}